# PartyWorld Docker stack — local environment
# Copy to docker/.env (done automatically by bootstrap_local.sh)
# SECRET_KEY is auto-generated on first run — change the rest as needed.

APP_USERNAME=admin
APP_PASSWORD=set-a-strong-password
SECRET_KEY=generate-with-openssl-rand-hex-32

# Optional — needed for receipt scanner / AI features
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
